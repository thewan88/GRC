# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=local
APP_KEY=                              # Generate: php artisan key:generate
APP_DEBUG=true

# Internal GRC URL (accessed by staff via browser)
APP_INTERNAL_URL=https://grc.internal.company.com

# External Trust Centre URL (publicly accessible)
TRUST_CENTRE_URL=https://trust.company.com

# ─── Database (MS SQL Server) ─────────────────────────────────────────────────
DB_CONNECTION=sqlsrv
DB_HOST=mssql                         # Docker service name; change to SQL Server IP for external
DB_PORT=1433
DB_DATABASE=grc
DB_USERNAME=sa
DB_PASSWORD=YourStrong!Passw0rd       # Change in production

# ─── Entra ID OAuth2 (Azure AD) ───────────────────────────────────────────────
# Register an App in Azure Portal → App registrations
# Redirect URI: https://grc.internal.company.com/api/v1/auth/callback
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=                      # Your tenant ID (or "common" for multi-tenant)
AZURE_REDIRECT_URI=https://grc.internal.company.com/api/v1/auth/callback

# ─── Laravel Sanctum (SPA Auth) ───────────────────────────────────────────────
# Comma-separated list of domains that are considered "stateful" (get session cookies)
SANCTUM_STATEFUL_DOMAINS=grc.internal.company.com,trust.company.com
SESSION_DOMAIN=.company.com           # Dot prefix shares cookie across subdomains
SESSION_LIFETIME=480                  # Minutes (8 hours for a working day)

# ─── Mail (Trust Centre access request notifications) ─────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit                     # Replace with your SMTP relay in production
MAIL_PORT=1025                        # Production: 587 (STARTTLS) or 465 (SSL)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null                  # Production: tls
MAIL_FROM_ADDRESS=grc@company.com
MAIL_FROM_NAME="GRC Platform"

# ─── Document Storage ──────────────────────────────────────────────────────────
# Path inside the backend container — bind-mount to Nutanix Files NFS share in prod
DOCUMENT_STORAGE_PATH=/var/grc-documents

# ─── Trust Centre Magic Link ───────────────────────────────────────────────────
TRUST_CENTRE_TOKEN_TTL_DAYS=7         # How long approved visitor tokens last

# ─── Nutanix Production Notes ─────────────────────────────────────────────────
# For Nutanix Files NFS document storage, update docker-compose.prod.yml:
#   volumes:
#     grc_documents:
#       driver: local
#       driver_opts:
#         type: nfs
#         o: addr=<nutanix-files-vip>,rw,hard,nointr
#         device: ":/grc-documents"
